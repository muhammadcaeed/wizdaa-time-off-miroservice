# Time-Off Service environment (TRD §14.4)
# Copy to .env and fill in. Required vars (no default) fail boot if missing.

# --- Service ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Database ---
# SQLite file path; WAL mode enabled at runtime. Required.
DATABASE_FILE=./data/time-off.sqlite

# --- Auth (HS256 JWT stub, ADR-003) ---
# Required. Use a long random string; never commit the real value.
JWT_SIGNING_KEY=replace-with-a-long-random-secret
JWT_LIFETIME_SECONDS=3600

# --- HCM client ---
# Base URL of the HCM (or the mock). Required.
HCM_BASE_URL=http://localhost:4001
# HCM_API_KEY=
HCM_TIMEOUT_MS=5000

# --- Circuit breaker (Cycle 03, ADR-008 / TRD §11.2) ---
HCM_BREAKER_FAILURE_THRESHOLD=5
HCM_BREAKER_FAILURE_RATE=0.5
HCM_BREAKER_COOLDOWN_MS=30000
# Max time an in-flight HALF_OPEN probe may run before it's treated as failed.
# Must exceed the full retry budget (~21s worst case) so a retrying probe isn't
# falsely declared dead.
HCM_BREAKER_PROBE_DEADLINE_MS=30000

# --- Retry (Cycle 03, TRD §11.3: base 100ms doubled per attempt, capped 5s) ---
HCM_RETRY_MAX_ATTEMPTS=3
HCM_RETRY_BASE_MS=100

# --- Reconciliation (TRD §9.2 / §11.4) ---
# Batch reconciliation cadence (ms). Default 60 min.
RECONCILE_INTERVAL_MS=3600000
# A request stuck in APPROVING/CANCELLING longer than this is swept (§11.4).
STUCK_STATE_THRESHOLD_MS=300000
# How often the stuck-state sweep scheduler runs (ms).
STUCK_STATE_SWEEP_INTERVAL_MS=60000

# --- Throttling (TRD §13.4 / api-contract §8: per-minute POST limits) ---
THROTTLE_PER_IP_PER_MIN=10
THROTTLE_PER_SUB_PER_MIN=30

# --- Idempotency (api-contract §6) ---
# Client idempotency record retention before cleanup prunes it (hours).
IDEMPOTENCY_TTL_HOURS=24

# --- Mock HCM (dev/test only, never production) ---
MOCK_HCM_PORT=4001
# Optional path to a JSON balance fixture for the mock; empty = built-in seed.
# MOCK_HCM_FIXTURE_PATH=
