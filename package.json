{
  "name": "wizdaa-time-off-microservice",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build time-off-service",
    "build:mock-hcm": "nest build mock-hcm",
    "format": "prettier --write \"apps/**/*.ts\"",
    "start": "nest start time-off-service",
    "start:dev": "nest start time-off-service --watch",
    "start:debug": "nest start time-off-service --debug --watch",
    "start:prod": "node dist/apps/time-off-service/main",
    "start:mock-hcm": "nest start mock-hcm --watch",
    "lint": "eslint \"apps/**/*.ts\" \"scripts/**/*.ts\" --fix",
    "lint:check": "eslint \"apps/**/*.ts\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "coverage": "vitest run --config ./vitest.config.coverage.ts --coverage",
    "verify:traceability": "ts-node --project scripts/tsconfig.json scripts/verify-traceability.ts",
    "ci": "npm run typecheck && npm run lint:check && npm run coverage && npm run verify:traceability",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d apps/time-off-service/src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d apps/time-off-service/src/database/data-source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d apps/time-off-service/src/database/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "better-sqlite3": "^12.10.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/core": "^1.15.40",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "fast-check": "^4.8.0",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.7"
  }
}
